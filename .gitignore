# Secrets & Credentials (CRITICAL)
# This keeps your Gemini API key and Supabase database passwords off the internet
.env

# Dependencies
# This folder contains thousands of downloaded packages; anyone cloning your project
# will download them automatically by running 'npm install' instead
node_modules/

# Compiled Production JavaScript
# This is the code generated by 'npx tsc'. Git only needs to track your original 'src/' folder
dist/

# Local Database & Prisma artifacts
# If you use a local SQLite database for quick testing, this stops it from uploading
*.db
*.db-journal

# Log files
# Error logs generated when software crashes locally
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# System Clutter
# Operating system thumbnail/folder configuration caches
.DS_Store
Thumbs.db